# dependencies
node_modules/
.pnp/
.pnp.*

# next.js
.next/
out/
build/
next-env.d.ts

# env (keep .env.example tracked)
.env.local
.env*.local

# manim intermediate render cache (final mp4s live in public/media)
manim/media*/
# stray LaTeX temp dir created if manim runs without --media_dir at repo root
/media/
__pycache__/
*.pyc
.venv/
venv/

# misc
.DS_Store
*.log
npm-debug.log*
yarn-error.log*
.vercel
*.tsbuildinfo
.idea/
.vscode/

# archived one-off scripts (not part of the app build)
/scripts/archive/
/scripts/logs/
/scripts/temp/

# ZIP files
*.zip

# Temporary files
tmp/
tmp_*

# Video files are hosted on CDN (see NEXT_PUBLIC_VIDEO_CDN_BASE).
# Posters (~1MB) stay in public/media/posters/ and are tracked.
public/media/videos/

# semantic search index (generated by npm run build-index)
content/.index/

.claude/
.trae/
