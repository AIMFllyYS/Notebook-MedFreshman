{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "nodeVersion": "22.17.1",
  "headers": [
    {
      "source": "/api/chat",
      "headers": [
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    },
    {
      "source": "/api/artifact",
      "headers": [
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": [],
      "maxDuration": 120
    }
  }
}
