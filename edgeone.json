{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "nodeVersion": "22.17.1",
  "headers": [
    {
      "source": "/api/chat",
      "headers": [
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    },
    {
      "source": "/api/artifact",
      "headers": [
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": [
        "content/chapters/**/*.md",
        "content/examples/**/*.md",
        "content/quiz/**/*.json",
        "content/probability/**/*.md",
        "content/chemistry/**/*.md",
        "content/physics/**/*.md",
        "content/maogai/**/*.md",
        "content/modern-history/**/*.md",
        "content/other/**/*.md",
        "content/**/*.html"
      ],
      "maxDuration": 120
    }
  }
}
