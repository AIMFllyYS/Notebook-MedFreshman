    "render:chapter": "python manim/render.py --chapter"
  },
  "dependencies": {
    "@vidstack/react": "1.15.6",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "framer-motion": "^11.18.0",
    "idb-keyval": "^6.2.5",
    "katex": "^0.16.21",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-directive": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
