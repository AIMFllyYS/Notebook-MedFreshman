    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
