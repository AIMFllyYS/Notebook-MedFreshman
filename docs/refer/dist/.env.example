# AI Configuration (OpenAI Compatible Format)
# Supports: OpenAI, DeepSeek, Ollama, or any OpenAI-compatible API

VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
VITE_AI_MODEL=gpt-4o
VITE_AI_API_KEY=sk-your-key-here

# Examples for other providers:
# DeepSeek:
# VITE_AI_API_URL=https://api.deepseek.com/v1/chat/completions
# VITE_AI_MODEL=deepseek-chat
# VITE_AI_API_KEY=sk-xxx

# Local Ollama:
# VITE_AI_API_URL=http://localhost:11434/v1/chat/completions
# VITE_AI_MODEL=qwen2.5:32b
# VITE_AI_API_KEY=ollama

# Web Search Configuration (Optional)
# Enable web search feature for AI assistant
# VITE_ENABLE_WEB_SEARCH=false
# VITE_SERPAPI_KEY=your-serpapi-key-here  # Get from https://serpapi.com
