# ── 右侧 AI 对话所用的 OpenAI 兼容端点（默认硅基流动 SiliconFlow）──────────
# 复制本文件为 .env.local 并填入真实值。.env.local 不会进入 git。

# 接口 base URL（需含 /v1，指向 /chat/completions 的上一级）
AI_BASE_URL=https://api.siliconflow.cn/v1

# API 密钥
AI_API_KEY=sk-xxxxxxxxxxxxxxxx

# env 默认模型（站点默认 AI）。前端模型菜单可临时切换到其他硅基流动模型，
# 或在「设置」里填入自定义 URL/API/模型后选择「自定义模型」（与 env 并存不冲突）。
AI_MODEL_PRO=deepseek-ai/DeepSeek-V4-Pro
AI_MODEL_FLASH=deepseek-ai/DeepSeek-V4-Flash

# 思考流字段名（DeepSeek/GLM/Qwen 系默认 reasoning_content；不同则改这里）
AI_REASONING_FIELD=reasoning_content

# 可选：若端点需要显式开关思考，置 1
AI_ENABLE_THINKING=

# ── 小米 MiMo 官方 API（独立于 SiliconFlow，MiMo 模型自动路由至此）───
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=

# ── 向量 / 重排（语义检索，复用 SiliconFlow 端点）────────────────────────
AI_EMBEDDING_MODEL=BAAI/bge-m3
AI_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# 可选：检索模式（hybrid/vector/keyword）。留空或 hybrid 为默认推荐。
AI_SEARCH_MODE=hybrid

# ── 语义检索索引 COS 托管 ────────────────────────────────────────────
# 索引文件（~307MB）不打包进 serverless 函数（outputFileTracingExcludes 排除），
# EdgeOne 运行时从 COS 下载到 /tmp 缓存，本地开发直接读 content/.index/。
# 留空则仅使用本地文件（本地开发模式）。
# 格式：https://<bucket>.cos.<region>.myqcloud.com/index/
COS_INDEX_BASE_URL=

# ── 联网搜索（智谱 Web Search API）──────────────────────────────────
# 在 https://open.bigmodel.cn 申请 key 后填入；留空则联网搜索工具返回"未配置"。
ZHIPU_API_KEY=

# ── 图片搜索（Unsplash API）──────────────────────────────────
# 在 https://unsplash.com/oauth/applications 申请 Access Key 后填入
# 留空则图片搜索工具返回"未配置"，使用 Demo 模式（50次/小时）
UNSPLASH_ACCESS_KEY=

# ── 视频 CDN 托管 ────────────────────────────────────────────────────
# MP4 文件（~900MB）已从仓库移除，托管在腾讯云 COS 或其他 CDN 上。
# 留空则视频从 public/media/videos/ 本地提供（需文件存在）。
# 设置后前端自动将 /media/videos/ 前缀替换为此 base URL。
NEXT_PUBLIC_VIDEO_CDN_BASE=

# ── 离线工具（非运行时，脚本使用）─────────────────────────────────────
# MinerU PDF 解析（scripts/parse-docs.ts 等脚本调用 OpenXLab API）
# 在 https://openxlab.org.cn 申请后填入。
# MinerU_API_Token=
