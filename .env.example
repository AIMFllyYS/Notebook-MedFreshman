# ── 右侧 AI 对话所用的 OpenAI 兼容端点（"deep thick"）─────────────────
# 复制本文件为 .env.local 并填入真实值。.env.local 不会进入 git。

# 接口 base URL（需含 /v1 或对应前缀，指向 /chat/completions 的上一级）
AI_BASE_URL=https://your-endpoint.example.com/v1

# API 密钥
AI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 两个可切换的模型 ID（UI 上标为 V4 Pro / V4 Flash）
AI_MODEL_PRO=your-v4-pro-model-id
AI_MODEL_FLASH=your-v4-flash-model-id

# 思考流字段名（DeepSeek 系默认 reasoning_content；不同则改这里）
AI_REASONING_FIELD=reasoning_content

# 可选：若端点需要显式开关思考，置 1
AI_ENABLE_THINKING=
